<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="AcmeCorp QA Test Generator"
                  exporterVersion="1.0.0">

  <!-- ============================================================ -->
  <!--  PROCESS: Document Approval Workflow                         -->
  <!--  Purpose: Test file for BPMN macro in Confluence             -->
  <!--  Contains: Start/End events, User/Service tasks, Gateways,  -->
  <!--            Parallel paths, Timer, Message events, Lanes      -->
  <!-- ============================================================ -->

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Approval" name="Document Approval Process" processRef="Process_Approval" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Approval" name="Document Approval Workflow" isExecutable="true">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Requester" name="Requester">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Revise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Reviewer" name="Reviewer">
        <bpmn:flowNodeRef>Task_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_ReviewDeadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Manager">
        <bpmn:flowNodeRef>Task_FinalApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Final</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyStakeholders</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchiveDocument</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Approved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- === Start === -->
    <bpmn:startEvent id="StartEvent_1" name="Document Created">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- === Requester Tasks === -->
    <bpmn:userTask id="Task_Submit" name="Submit Document for Review">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_Revise_Back</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_Revise" name="Revise Document">
      <bpmn:incoming>Flow_NeedsWork</bpmn:incoming>
      <bpmn:outgoing>Flow_Revise_Back</bpmn:outgoing>
    </bpmn:userTask>

    <!-- === Review === -->
    <bpmn:userTask id="Task_Review" name="Review Document">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_ReviewDeadline" name="3 Business Days" attachedToRef="Task_Review" cancelActivity="false">
      <bpmn:timerEventDefinition id="TimerDef_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- === Review Decision Gateway === -->
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Review Decision">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedsWork</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- === Manager Final Approval === -->
    <bpmn:userTask id="Task_FinalApproval" name="Final Manager Approval">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Final" name="Final Decision">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_FinalOK</bpmn:outgoing>
      <bpmn:outgoing>Flow_FinalReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- === Parallel Post-Approval Tasks === -->
    <bpmn:parallelGateway id="Gateway_Parallel_Split" name="Split">
      <bpmn:incoming>Flow_FinalOK</bpmn:incoming>
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Task_NotifyStakeholders" name="Notify Stakeholders (Email)">
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P1_Done</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_ArchiveDocument" name="Archive Document in DMS">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:outgoing>Flow_P2_Done</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:parallelGateway id="Gateway_Parallel_Join" name="Join">
      <bpmn:incoming>Flow_P1_Done</bpmn:incoming>
      <bpmn:incoming>Flow_P2_Done</bpmn:incoming>
      <bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- === End Events === -->
    <bpmn:endEvent id="EndEvent_Approved" name="Document Approved ✅">
      <bpmn:incoming>Flow_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Document Rejected ❌">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:incoming>Flow_FinalReject</bpmn:incoming>
    </bpmn:endEvent>

    <!-- === Sequence Flows === -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Submit" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Submit" targetRef="Task_Review" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Review" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_Approved" name="Approved" sourceRef="Gateway_Decision" targetRef="Task_FinalApproval" />
    <bpmn:sequenceFlow id="Flow_NeedsWork" name="Needs Revision" sourceRef="Gateway_Decision" targetRef="Task_Revise" />
    <bpmn:sequenceFlow id="Flow_Rejected" name="Rejected" sourceRef="Gateway_Decision" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_Revise_Back" sourceRef="Task_Revise" targetRef="Task_Submit" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_FinalApproval" targetRef="Gateway_Final" />
    <bpmn:sequenceFlow id="Flow_FinalOK" name="Approved" sourceRef="Gateway_Final" targetRef="Gateway_Parallel_Split" />
    <bpmn:sequenceFlow id="Flow_FinalReject" name="Rejected" sourceRef="Gateway_Final" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_P1" sourceRef="Gateway_Parallel_Split" targetRef="Task_NotifyStakeholders" />
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="Gateway_Parallel_Split" targetRef="Task_ArchiveDocument" />
    <bpmn:sequenceFlow id="Flow_P1_Done" sourceRef="Task_NotifyStakeholders" targetRef="Gateway_Parallel_Join" />
    <bpmn:sequenceFlow id="Flow_P2_Done" sourceRef="Task_ArchiveDocument" targetRef="Gateway_Parallel_Join" />
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Gateway_Parallel_Join" targetRef="EndEvent_Approved" />

  </bpmn:process>

  <!-- ============================================================ -->
  <!--  DIAGRAM: Visual layout for BPMN rendering                  -->
  <!-- ============================================================ -->

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_Approval_di" bpmnElement="Participant_Approval" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1340" height="620" />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Requester_di" bpmnElement="Lane_Requester" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1310" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Reviewer_di" bpmnElement="Lane_Reviewer" isHorizontal="true">
        <dc:Bounds x="190" y="260" width="1310" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="190" y="460" width="1310" height="220" />
      </bpmndi:BPMNShape>

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="232" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="208" y="185" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Submit Task -->
      <bpmndi:BPMNShape id="Task_Submit_di" bpmnElement="Task_Submit">
        <dc:Bounds x="330" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Review Task -->
      <bpmndi:BPMNShape id="Task_Review_di" bpmnElement="Task_Review">
        <dc:Bounds x="500" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Timer -->
      <bpmndi:BPMNShape id="Timer_ReviewDeadline_di" bpmnElement="Timer_ReviewDeadline">
        <dc:Bounds x="562" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="598" y="403" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Review Decision Gateway -->
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="665" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="725" y="353" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Revise Task -->
      <bpmndi:BPMNShape id="Task_Revise_di" bpmnElement="Task_Revise">
        <dc:Bounds x="640" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Final Approval -->
      <bpmndi:BPMNShape id="Task_FinalApproval_di" bpmnElement="Task_FinalApproval">
        <dc:Bounds x="750" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Final Decision Gateway -->
      <bpmndi:BPMNShape id="Gateway_Final_di" bpmnElement="Gateway_Final" isMarkerVisible="true">
        <dc:Bounds x="905" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="895" y="592" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Parallel Split -->
      <bpmndi:BPMNShape id="Gateway_Parallel_Split_di" bpmnElement="Gateway_Parallel_Split">
        <dc:Bounds x="1005" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- Notify Task -->
      <bpmndi:BPMNShape id="Task_NotifyStakeholders_di" bpmnElement="Task_NotifyStakeholders">
        <dc:Bounds x="1100" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Archive Task -->
      <bpmndi:BPMNShape id="Task_ArchiveDocument_di" bpmnElement="Task_ArchiveDocument">
        <dc:Bounds x="1100" y="590" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Parallel Join -->
      <bpmndi:BPMNShape id="Gateway_Parallel_Join_di" bpmnElement="Gateway_Parallel_Join">
        <dc:Bounds x="1255" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- End Approved -->
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="1362" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1330" y="585" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End Rejected -->
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="832" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="800" y="185" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- === Edges === -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="268" y="160" />
        <di:waypoint x="330" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="160" />
        <di:waypoint x="465" y="160" />
        <di:waypoint x="465" y="360" />
        <di:waypoint x="500" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="600" y="360" />
        <di:waypoint x="665" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approved_di" bpmnElement="Flow_Approved">
        <di:waypoint x="690" y="385" />
        <di:waypoint x="690" y="560" />
        <di:waypoint x="750" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="695" y="470" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NeedsWork_di" bpmnElement="Flow_NeedsWork">
        <di:waypoint x="690" y="335" />
        <di:waypoint x="690" y="200" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="695" y="263" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Rejected_di" bpmnElement="Flow_Rejected">
        <di:waypoint x="715" y="360" />
        <di:waypoint x="850" y="360" />
        <di:waypoint x="850" y="178" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="760" y="342" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Revise_Back_di" bpmnElement="Flow_Revise_Back">
        <di:waypoint x="640" y="160" />
        <di:waypoint x="430" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="850" y="560" />
        <di:waypoint x="905" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FinalOK_di" bpmnElement="Flow_FinalOK">
        <di:waypoint x="955" y="560" />
        <di:waypoint x="1005" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="957" y="542" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FinalReject_di" bpmnElement="Flow_FinalReject">
        <di:waypoint x="930" y="535" />
        <di:waypoint x="930" y="160" />
        <di:waypoint x="868" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="935" y="345" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <di:waypoint x="1030" y="535" />
        <di:waypoint x="1030" y="520" />
        <di:waypoint x="1100" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <di:waypoint x="1030" y="585" />
        <di:waypoint x="1030" y="630" />
        <di:waypoint x="1100" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P1_Done_di" bpmnElement="Flow_P1_Done">
        <di:waypoint x="1200" y="520" />
        <di:waypoint x="1280" y="520" />
        <di:waypoint x="1280" y="535" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_Done_di" bpmnElement="Flow_P2_Done">
        <di:waypoint x="1200" y="630" />
        <di:waypoint x="1280" y="630" />
        <di:waypoint x="1280" y="585" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_End_di" bpmnElement="Flow_End">
        <di:waypoint x="1305" y="560" />
        <di:waypoint x="1362" y="560" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
